# ── BooksBot environment ──────────────────────────────────────────────────────
# Copy to .env for local dev; on Koyeb/Render set these in the env panel.

# Telegram
BOT_TOKEN=123456:ABC-yourtoken
BOT_USERNAME=getfreebooksbot
SUPER_ADMIN_ID=6011680723
ADMIN_IDS=                      # extra normal admins, comma-separated

# Optional coloured-button-capable Bot API server. Leave blank for official API.
TELEGRAM_API_BASE=
COLORED_BUTTONS=true            # set false if your API server rejects style fields

# MongoDB — use any one form. Multiple URLs = automatic failover when one fills.
MONGO_URL=mongodb+srv://user:pass@cluster0.xxxx.mongodb.net/?retryWrites=true&w=majority
# MONGO_URLS=mongodb+srv://...,mongodb+srv://...
# MONGO_URL_1=...
# MONGO_URL_2=...
MONGO_DB_NAME=booksbot

# Channels
REQUIRED_CHANNELS=@Bookslibraryofficial,@eternalmantra,@thesciencelabs
FILE_CHANNEL_ID=-1001234567890  # private channel with the ~30k files
LOG_CHANNEL_ID=-1002597047059

# Telethon backfill (tools/backfill.py only — index the file channel history)
API_ID=
API_HASH=
TELETHON_SESSION=

# Web / Mini Apps
PORT=8080
BOT_PUBLIC_URL=https://your-app.koyeb.app

# Economy
BCN_EXPIRY_SECONDS=86400

# Payments (Buy BGM)
# IMPORTANT — SHARED FamPay with the inflowads (Onflow Ads) bot: keep UPI_ID
# identical to that bot's FAMPAY_UPI_ID, and point IMAP_USER at the SAME Gmail
# both bots poll. That shared inbox + UPI ID is what makes "whichever bot the
# UTR is submitted to credits the payment" work (each bot only credits orders in
# its own DB, so there is no cross-bot double-credit).
UPI_ID=sendrajbooks@fam
PAYMENT_QR_URL=                 # static QR image URL (optional)
BGM_PRICE_INR=2
BGM_PRICE_USD=0.023
MIN_BGM_PURCHASE=10
# UPI auto-verify via email (FamPay receipts → this Gmail). Use a Gmail
# App Password, not your login password. Same inbox as inflowads.
IMAP_HOST=imap.gmail.com
IMAP_USER=rajsom8877@gmail.com
IMAP_PASSWORD=                  # Gmail app password
FAMPAY_SENDER=no-reply@famapp.in
EMAIL_LOG_CHANNEL=              # -100… channel for UPI credit logs (optional)
# Crypto via Cryptomus (https://cryptomus.com — accepts almost every coin).
# Webhook: <BOT_PUBLIC_URL>/cryptomus-webhook (sent automatically per invoice).
CRYPTOMUS_API_KEY=
CRYPTOMUS_MERCHANT_ID=

# AI features (recommendations / summaries / genre tagging).
# Default provider is the FREE bots.lt GPT API — no key needed, works out of the
# box. Switch provider + set a Claude key live from /admin → 🤖 AI Settings
# (or the /admin Mini-App dashboard). These env vars are optional fallbacks.
ANTHROPIC_API_KEY=             # optional — only if you switch the provider to Claude
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Anti-bot captcha (safe in-house emoji-tap; replaces 3rd-party verification)
CAPTCHA_ENABLED=false
CAPTCHA_TTL_SECONDS=604800

# Automated backups — config/economy state (kv/codes/coupons/questions) is posted
# as JSON to the backup channel (kv `backup_channel`, else LOG_CHANNEL_ID) on a
# loop. Trigger on demand from /admin → 🧰 More Tools → 🩺 Health → 📦 Backup Now.
BACKUP_INTERVAL_HOURS=24
